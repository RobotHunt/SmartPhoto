import { useState } from "react";
import { useLocation } from "wouter";
import { Upload, X } from "lucide-react";
import { Button } from "@/components/ui/button";
import { Checkbox } from "@/components/ui/checkbox";

interface UploadedFile {
  file: File;
  preview: string;
}

export default function UploadStep() {
  const [, setLocation] = useLocation();
  const [isDragging, setIsDragging] = useState(false);
  const [uploadedFiles, setUploadedFiles] = useState<UploadedFile[]>([]);

  const handleFileSelect = (files: FileList | null) => {
    if (!files || files.length === 0) return;
    
    // 创建文件预览
    const newFiles: UploadedFile[] = Array.from(files).map(file => ({
      file,
      preview: URL.createObjectURL(file)
    }));
    
    setUploadedFiles(prev => [...prev, ...newFiles]);
  };

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault();
    setIsDragging(false);
    handleFileSelect(e.dataTransfer.files);
  };

  const handleDragOver = (e: React.DragEvent) => {
    e.preventDefault();
    setIsDragging(true);
  };

  const handleDragLeave = () => {
    setIsDragging(false);
  };

  const triggerFileInput = () => {
    const input = document.createElement('input');
    input.type = 'file';
    input.multiple = true;
    input.accept = 'image/*';
    input.onchange = (e) => {
      const target = e.target as HTMLInputElement;
      handleFileSelect(target.files);
    };
    input.click();
  };

  const removeFile = (index: number) => {
    setUploadedFiles(prev => {
      const newFiles = [...prev];
      // 释放URL对象
      URL.revokeObjectURL(newFiles[index].preview);
      newFiles.splice(index, 1);
      return newFiles;
    });
  };

  const handleStartAnalysis = () => {
    if (uploadedFiles.length === 0) return;
    
    // 保存上传的文件信息到sessionStorage
    const fileNames = uploadedFiles.map(f => f.file.name);
    sessionStorage.setItem("uploadedImages", JSON.stringify(fileNames));
    sessionStorage.setItem("uploadedCount", uploadedFiles.length.toString());
    
    // 进入AI分析页面
    setLocation("/create/analyze");
  };

  return (
    <div className="min-h-screen bg-white">
      {/* 页面标题 */}
      <div className="text-center pt-12 pb-8">
        <div className="inline-flex items-center gap-2 mb-6">
          <span className="text-teal-600 font-bold text-xl">扫描AI</span>
        </div>
        <h1 className="text-4xl font-bold text-slate-900 mb-8">
          开始生成您的产品图片
        </h1>

        {/* 简化步骤指示器 */}
        <div className="flex items-center justify-center gap-4 mb-2">
          <div className="flex items-center gap-2">
            <div className="w-10 h-10 rounded-full bg-teal-500 text-white flex items-center justify-center font-bold">
              1
            </div>
            <div className="w-16 h-0.5 bg-slate-300" />
          </div>
          <div className="flex items-center gap-2">
            <div className="w-10 h-10 rounded-full bg-slate-200 text-slate-600 flex items-center justify-center font-bold">
              2
            </div>
            <div className="w-16 h-0.5 bg-slate-300" />
          </div>
          <div className="flex items-center gap-2">
            <div className="w-10 h-10 rounded-full bg-slate-200 text-slate-600 flex items-center justify-center font-bold">
              3
            </div>
            <div className="w-16 h-0.5 bg-slate-300" />
          </div>
          <div className="w-10 h-10 rounded-full bg-slate-200 text-slate-600 flex items-center justify-center font-bold">
            6
          </div>
        </div>
        <p className="text-sm text-slate-500">3步快速就绪，清爽</p>
      </div>

      {/* 主内容区域 */}
      <div className="container mx-auto px-4 max-w-md">
        <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <h2 className="text-2xl font-bold text-center mb-6">上传产品图</h2>

          {/* Checkbox提示 */}
          <div className="flex items-center gap-2 mb-6 text-sm text-slate-600">
            <Checkbox id="auto-optimize" defaultChecked />
            <label htmlFor="auto-optimize" className="cursor-pointer">
              草皮上传可被缩略片分类，帮助推荐适图
            </label>
          </div>

          {/* 两个并排的图片占位框 */}
          <div 
            className="grid grid-cols-2 gap-4 mb-6"
            onDrop={handleDrop}
            onDragOver={handleDragOver}
            onDragLeave={handleDragLeave}
          >
            {/* 显示已上传的图片 */}
            {uploadedFiles.map((item, index) => (
              <div key={index} className="relative group aspect-square">
                <div className="w-full h-full rounded-lg overflow-hidden bg-slate-100 border border-slate-200">
                  <img
                    src={item.preview}
                    alt={`上传图片 ${index + 1}`}
                    className="w-full h-full object-cover"
                  />
                </div>
                {/* 删除按钮 */}
                <button
                  onClick={() => removeFile(index)}
                  className="absolute -top-2 -right-2 w-6 h-6 bg-slate-800 text-white rounded-full flex items-center justify-center hover:bg-slate-900 transition-colors z-10"
                >
                  <X className="w-4 h-4" />
                </button>
              </div>
            ))}
            
            {/* 空的占位框（最多显示2个） */}
            {Array.from({ length: Math.max(0, 2 - uploadedFiles.length) }).map((_, index) => (
              <div
                key={`placeholder-${index}`}
                onClick={triggerFileInput}
                className={`
                  aspect-square rounded-lg border-2 border-dashed flex flex-col items-center justify-center cursor-pointer transition-colors
                  ${isDragging 
                    ? 'border-teal-500 bg-teal-50' 
                    : 'border-slate-300 hover:border-teal-400 hover:bg-slate-50'
                  }
                `}
              >
                <div className="w-12 h-12 mb-3 text-slate-400">
                  <Upload className="w-full h-full" />
                </div>
                <div className="text-sm font-medium text-slate-900 mb-1">
                  上传产品图片
                </div>
                <div className="text-xs text-slate-500 px-4 text-center">
                  点击或拖拽图片到此区域上传
                </div>
                <div className="text-xs text-slate-400 mt-2">
                  支持 JPG、PNG 格式，建议尺寸 1000x1000 以上
                </div>
              </div>
            ))}
          </div>

          {/* 底部提示 */}
          <div className="flex items-center justify-center gap-2 text-sm text-slate-600 mb-6">
            <span>全部选图像片片，并抵台测减图</span>
            <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" strokeWidth="2"/>
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 16v-4m0-4h.01"/>
            </svg>
          </div>

          {/* 开始AI生图按钮 */}
          <Button
            onClick={handleStartAnalysis}
            disabled={uploadedFiles.length === 0}
            className="w-full bg-teal-500 hover:bg-teal-600 text-white py-6 text-lg rounded-full disabled:opacity-50 disabled:cursor-not-allowed"
          >
            开始AI生图
            <svg className="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 5l7 7-7 7"/>
            </svg>
          </Button>
        </div>
      </div>
    </div>
  );
}
