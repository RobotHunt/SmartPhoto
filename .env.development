# Local development - use Vite proxy to avoid CORS
# Leave VITE_API_BASE_URL empty to use the default '/api/v2' which goes through Vite proxy
# VITE_API_BASE_URL=

# Enable Vite proxy for local development
VITE_LOCAL_PROXY_TARGET=https://smartphoto.ins.chat

# Required for local proxy injection of X-App-Key.
# LOCAL_PROXY_X_APP_KEY=replace-with-your-local-app-key
