{
  // 项目名称
  "name": "smartphoto-frontend",

  // 边缘函数入口（ESA Edge Routine）
  // 处理 /api/v2/* 请求，转发到后端服务器
  "entry": "./functions/api.js",

  // 无需安装依赖（纯静态项目）
  "installCommand": "",

  // 无需构建（原生 HTML/CSS/JS）
  "buildCommand": "",

  // 静态资源配置
  "assets": {
    // 静态文件就在项目根目录
    "directory": ".",

    // SPA 路由回退：未匹配到静态文件时返回 index.html
    "notFoundStrategy": "singlePageApplication"
  }
}
