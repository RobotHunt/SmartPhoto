# SmartPhoto Frontend - Example local env

# Local backend target for the Vite dev proxy.
VITE_LOCAL_PROXY_TARGET=http://127.0.0.1:8000

# Required when VITE_LOCAL_PROXY_TARGET is set.
# This value is read only by vite.config.ts and injected by the local proxy.
LOCAL_PROXY_X_APP_KEY=replace-with-your-local-app-key
